# ─── Authentication ───────────────────────────────────────────────────────────
# Set to "1" to enable auth (token-based). Default: disabled.
SPORTS_SIM_AUTH_ENABLED=0
# HMAC secret for signing tokens. REQUIRED when auth is enabled.
SPORTS_SIM_AUTH_SECRET=change-me-to-a-long-random-string

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Default: localhost dev ports.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ─── Cache / Redis ────────────────────────────────────────────────────────────
# Optional Redis URL. If unset, uses in-memory cache.
# REDIS_URL=redis://localhost:6379/0

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Requests per minute per IP. Default: 120
RATE_LIMIT_RPM=120
# Burst capacity. Default: 20
RATE_LIMIT_BURST=20

# ─── Tuning Scheduler ────────────────────────────────────────────────────────
# Interval in seconds for background tuning jobs. Default: 3600
TUNER_INTERVAL=3600

# ─── Server ───────────────────────────────────────────────────────────────────
# Host and port for uvicorn. These are passed on the command line, not read by
# the app directly, but documented here for convenience.
# HOST=0.0.0.0
# PORT=8000
