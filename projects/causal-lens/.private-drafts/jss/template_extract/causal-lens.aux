\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces  NHEFS benchmark: treatment-effect estimates and 95\% confidence intervals for the smoking-cessation weight-gain question. All estimates fall within 0.12~kg of each other \citep  {HernanRobins2020}. The close agreement across estimators emphasizes that the empirical conclusion is not being driven by a single adjustment strategy on this benchmark.}}{7}{figure.2}\protected@file@percent }
\newlabel{fig:nhefs}{{2}{7}{NHEFS benchmark: treatment-effect estimates and 95\% confidence intervals for the smoking-cessation weight-gain question. All estimates fall within 0.12~kg of each other \citep {HernanRobins2020}. The close agreement across estimators emphasizes that the empirical conclusion is not being driven by a single adjustment strategy on this benchmark}{figure.2}{}}
